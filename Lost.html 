<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تقديم بلاغ - فتش عربيتك وعربية جارك</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f9; padding: 20px; }
        .container { max-width: 600px; background: white; padding: 20px; border-radius: 10px; margin: auto; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #d9534f; }
        .payment-info { background-color: #fff3f3; padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 2px solid #d9534f; }
        .price-tag { font-size: 24px; color: #d9534f; text-align: center; display: block; margin-bottom: 10px; font-weight: bold; }
        label { font-weight: bold; display: block; margin-top: 15px; }
        input { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; }
        button { width: 100%; background-color: #d9534f; color: white; border: none; padding: 15px; font-size: 18px; font-weight: bold; border-radius: 5px; margin-top: 20px; cursor: pointer; }
        button:hover { background-color: #c9302c; }
    </style>
</head>
<body>

<div class="container">
    <h2>تقديم بلاغ عن عربية مفقودة</h2>
    
    <div class="payment-info">
        <span class="price-tag">قيمة البلاغ: 5,000</span>
        <strong>خطوات تقديم البلاغ:</strong><br>
        1. يرجى تحويل المبلغ الموضح أعلاه إلى رقم الحساب: <b>2113114</b><br>
        باسم: <b>سعد قسم الباري</b><br>
        2. احتفظ برقم الإشعار لإدخاله في النموذج أدناه.<br>
        3. عند الإرسال، سيتم توجيهك لواتساب لإرسال صورة الإشعار وتأكيد البلاغ.
    </div>

    <form id="reportForm">
        <label>نوع العربية:</label>
        <input type="text" id="carType" placeholder="مثال: تويوتا هايلوكس 2020" required>

        <label>رقم الشاسي:</label>
        <input type="text" id="chassisNum" placeholder="أدخل آخر أرقام الشاسي بعد الأحرف" required>

        <label>رقم اللوحة:</label>
        <input type="text" id="plateNum" placeholder="أدخل رقم اللوحة">

        <label>رقم هاتف الزائر (للتواصل):</label>
        <input type="tel" id="visitorPhone" placeholder="أدخل رقم هاتفك" required>

        <label>رقم إشعار التحويل البنكي:</label>
        <input type="text" id="receiptNum" placeholder="أدخل رقم الإشعار" required>

        <button type="button" onclick="sendToWhatsApp()">إرسال البلاغ (5,000)</button>
    </form>
</div>

<script>
    function sendToWhatsApp() {
        var carType = document.getElementById("carType").value;
        var chassisNum = document.getElementById("chassisNum").value;
        var plateNum = document.getElementById("plateNum").value;
        var visitorPhone = document.getElementById("visitorPhone").value;
        var receiptNum = document.getElementById("receiptNum").value;

        if(carType === "" || chassisNum === "" || visitorPhone === "" || receiptNum === "") {
            alert("الرجاء ملء جميع الحقول المطلوبة ورقم الإشعار!");
            return;
        }

        var message = "🚨 *بلاغ سيارة مفقودة جديد* 🚨%0a%0a" +
                      "🚙 *نوع العربية:* " + carType + "%0a" +
                      "🔢 *آخر أرقام الشاسي:* " + chassisNum + "%0a" +
                      "🏷️ *رقم اللوحة:* " + plateNum + "%0a" +
                      "📞 *رقم الزائر:* " + visitorPhone + "%0a" +
                      "🧾 *رقم إشعار التحويل:* " + receiptNum + "%0a" +
                      "💰 *القيمة المستلمة:* 5,000";

        var adminPhone = "249100030140"; 
        var whatsappUrl = "https://wa.me/" + adminPhone + "?text=" + message;
        window.open(whatsappUrl, '_blank');
    }
</script>

</body>
</html>
